{
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "cleanUrls": true,
  "rewrites": [
    { "source": "/explore", "destination": "/index.html" },
    { "source": "/adventure", "destination": "/index.html" },
    { "source": "/when", "destination": "/index.html" },
    { "source": "/plan", "destination": "/index.html" },
    { "source": "/lads", "destination": "/index.html" },
    { "source": "/gift/:slug*", "destination": "/index.html" },
    { "source": "/rome", "destination": "/index.html" },
    { "source": "/australia", "destination": "/index.html" },
    { "source": "/prague", "destination": "/index.html" },
    { "source": "/dublin", "destination": "/index.html" },
    { "source": "/michigan", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ]
}
